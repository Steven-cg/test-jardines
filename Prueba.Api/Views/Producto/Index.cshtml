@model IEnumerable<Prueba.Entities.Producto>
@{
    ViewBag.Title = "Mantenimiento de Productos";
}

<div class="container" style="margin-top: 20px;">
    <h2 class="text-primary">Gestión de Inventario</h2>
    <hr />

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="well">
        <h4>Registrar Nuevo Producto</h4>
        @using (Html.BeginForm("Guardar", "Producto", FormMethod.Post, new { @class = "form-inline" }))
        {
            <div class="form-group">
                <label>Nombre:</label>
                <input type="text" name="Nombre" class="form-control" placeholder="Ej: Laptop" required />
            </div>
            <div class="form-group" style="margin-left:10px;">
                <label>Precio:</label>
                <input type="number" step="0.01" name="Precio" class="form-control" placeholder="0.00" required />
            </div>
            <div class="form-group" style="margin-left:10px;">
                <label>Stock:</label>
                <input type="number" name="Stock" class="form-control" placeholder="0" required />
            </div>
            
            <div style="margin-top: 15px;">
                <button type="submit" class="btn btn-success">
                    <span class="glyphicon glyphicon-save"></span> Insertar
                </button>
                <a href="@Url.Action("Index")" class="btn btn-info">
                    <span class="glyphicon glyphicon-search"></span> Consultar
                </a>
            </div>
        }
    </div>

    <div style="margin-top: 30px;">
        <table class="table table-bordered table-striped">
            <thead class="bg-primary" style="color: white;">
                <tr>
                    <th>ID</th>
                    <th>Descripción</th>
                    <th>Precio Unitario</th>
                    <th>Stock</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Nombre</td>
                            <td>$ @item.Precio.ToString("N2")</td>
                            <td>@item.Stock</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No hay registros disponibles.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
